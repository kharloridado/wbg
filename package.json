{
  "name": "outsystems-project-template",
  "version": "0.6.0",
  "description": "OutSystems frontend project scaffold — lightningcss theme pipeline + findings workflow",
  "private": true,
  "scripts": {
    "gen:color-utilities": "node build/gen-color-utilities.mjs",
    "gen:type-utilities": "node build/gen-type-utilities.mjs",
    "gen:spacing-utilities": "node build/gen-spacing-utilities.mjs",
    "gen:icon-data": "node build/gen-icon-data.mjs",
    "gen:fa-css": "node build/gen-fa-pro-css.mjs",
    "gen:icomoon": "node build/gen-icomoon.mjs",
    "gen:icomoon-data": "node build/gen-icomoon-data.mjs",
    "convert:fa-otf": "node build/convert-fa-otf.mjs",
    "build:theme": "node build/build-theme.mjs",
    "check:live-theme": "node build/check-live-theme.mjs",
    "build:theme:ship": "node build/build-theme.mjs --ship",
    "build:fontawesome": "node build/build-fontawesome.mjs",
    "watch:theme": "node build/build-theme.mjs --watch",
    "build:osui": "node build/build-osui.mjs",
    "preview": "node build/preview-server.mjs",
    "build:theme:min": "lightningcss --bundle --minify --targets \">= 0.25%\" tokens/index.css -o dist/theme.min.css"
  },
  "devDependencies": {
    "lightningcss-cli": "^1.0.0",
    "sass": "^1.77.4",
    "wawoff2": "^2.0.1"
  }
}
